{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Local Server",
      "type": "shell",
      "command": "python3",
      "args": [
        "-m",
        "http.server",
        "8000"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": false,
          "beginsPattern": "^.*Serving HTTP.*",
          "endsPattern": "^.*$"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
